# Supabase — public values (exposed to the client bundle)
# Find both at: Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase — local tooling only (NOT exposed to client)
# Used by `npm run db:types` to know which project to generate from.
# Find it at: Dashboard → Settings → General → Reference ID
SUPABASE_PROJECT_ID=your-project-ref-id
# Client's Company Name
VITE_COMPANY_NAME=Your Company Name
#BigData APIKey
BIGDATA_API_KEY=your_bigdata_api_key